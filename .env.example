# Postgres (Neon)
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# next-auth v5
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_YANDEX_CLIENT_ID=
AUTH_YANDEX_CLIENT_SECRET=
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=


# canfly SSO client mode for subdomains/apps
AUTH_CANFLY_ISSUER=https://canfly.org/oidc
AUTH_CANFLY_WELL_KNOWN=
AUTH_CANFLY_CLIENT_ID=
AUTH_CANFLY_CLIENT_SECRET=
NEXT_PUBLIC_CANFLY_SSO_ENABLED=false

# OpenAI (через Vercel AI Gateway)
OPENAI_API_KEY=sk-xxx

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
